{
  "name": "lockgraph",
  "version": "0.0.0-snapshot.93",
  "private": false,
  "description": "Universal lockfile model and converter for npm, yarn, pnpm, bun",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./modify": {
      "types": "./dist/modify/index.d.ts",
      "default": "./dist/modify/index.js"
    },
    "./complete": {
      "types": "./dist/complete/index.d.ts",
      "default": "./dist/complete/index.js"
    },
    "./optimize": {
      "types": "./dist/optimize/index.d.ts",
      "default": "./dist/optimize/index.js"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "default": "./dist/registry/index.js"
    },
    "./enrich": {
      "types": "./dist/enrich/index.d.ts",
      "default": "./dist/enrich/index.js"
    },
    "./formats/bun-text": {
      "types": "./dist/formats/bun-text.d.ts",
      "default": "./dist/formats/bun-text.js"
    },
    "./formats/npm-1": {
      "types": "./dist/formats/npm-1.d.ts",
      "default": "./dist/formats/npm-1.js"
    },
    "./formats/npm-2": {
      "types": "./dist/formats/npm-2.d.ts",
      "default": "./dist/formats/npm-2.js"
    },
    "./formats/npm-3": {
      "types": "./dist/formats/npm-3.d.ts",
      "default": "./dist/formats/npm-3.js"
    },
    "./formats/pnpm-v5": {
      "types": "./dist/formats/pnpm-v5.d.ts",
      "default": "./dist/formats/pnpm-v5.js"
    },
    "./formats/pnpm-v6": {
      "types": "./dist/formats/pnpm-v6.d.ts",
      "default": "./dist/formats/pnpm-v6.js"
    },
    "./formats/pnpm-v9": {
      "types": "./dist/formats/pnpm-v9.d.ts",
      "default": "./dist/formats/pnpm-v9.js"
    },
    "./formats/yarn-berry-v4": {
      "types": "./dist/formats/yarn-berry-v4.d.ts",
      "default": "./dist/formats/yarn-berry-v4.js"
    },
    "./formats/yarn-berry-v5": {
      "types": "./dist/formats/yarn-berry-v5.d.ts",
      "default": "./dist/formats/yarn-berry-v5.js"
    },
    "./formats/yarn-berry-v6": {
      "types": "./dist/formats/yarn-berry-v6.d.ts",
      "default": "./dist/formats/yarn-berry-v6.js"
    },
    "./formats/yarn-berry-v7": {
      "types": "./dist/formats/yarn-berry-v7.d.ts",
      "default": "./dist/formats/yarn-berry-v7.js"
    },
    "./formats/yarn-berry-v8": {
      "types": "./dist/formats/yarn-berry-v8.d.ts",
      "default": "./dist/formats/yarn-berry-v8.js"
    },
    "./formats/yarn-berry-v9": {
      "types": "./dist/formats/yarn-berry-v9.d.ts",
      "default": "./dist/formats/yarn-berry-v9.js"
    },
    "./formats/yarn-berry-v10": {
      "types": "./dist/formats/yarn-berry-v10.d.ts",
      "default": "./dist/formats/yarn-berry-v10.js"
    },
    "./formats/yarn-classic": {
      "types": "./dist/formats/yarn-classic.d.ts",
      "default": "./dist/formats/yarn-classic.js"
    },
    "./formats/lockgraph": {
      "types": "./dist/formats/lockgraph.d.ts",
      "default": "./dist/formats/lockgraph.js"
    }
  },
  "typesVersions": {
    "*": {
      "modify": [
        "./dist/modify/index.d.ts"
      ],
      "complete": [
        "./dist/complete/index.d.ts"
      ],
      "optimize": [
        "./dist/optimize/index.d.ts"
      ],
      "registry": [
        "./dist/registry/index.d.ts"
      ],
      "enrich": [
        "./dist/enrich/index.d.ts"
      ],
      "formats/*": [
        "./dist/formats/*.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "SCHEMAS.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=14.18"
  },
  "scripts": {
    "build": "node scripts/clean.mjs && rollup -c && tsc -p tsconfig.dts.json && node scripts/fix-dts.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "gen:fixtures": "node src/test/resources/fixtures/_gen.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "node-fetch-native": "^1.6.7",
    "pako": "^3.0.0",
    "semver": "^7.8.5"
  },
  "devDependencies": {
    "@antongolub/artel": "^0.4.0",
    "@size-limit/file": "^12.1.0",
    "@types/node": "^22.10.0",
    "@types/pako": "^2.0.4",
    "@types/semver": "^7.7.1",
    "@yarnpkg/libzip": "^3.2.2",
    "bun": "1.2.0",
    "pm-npm-10": "npm:npm@10.9.2",
    "pm-npm-11": "npm:npm@11.0.0",
    "pm-npm-12": "npm:npm@12.0.1",
    "pm-npm-6": "npm:npm@6.14.18",
    "pm-npm-7": "npm:npm@7.24.2",
    "pm-npm-8": "npm:npm@8.19.4",
    "pm-npm-9": "npm:npm@9.9.4",
    "pm-pnpm-10": "npm:pnpm@10.0.0",
    "pm-pnpm-6": "npm:pnpm@6.35.1",
    "pm-pnpm-7": "npm:pnpm@7.33.7",
    "pm-pnpm-8": "npm:pnpm@8.15.9",
    "pm-pnpm-9": "npm:pnpm@9.15.0",
    "pm-yarn-1": "npm:yarn@1.22.22",
    "pm-yarn-2": "npm:yarn@2.4.3",
    "rollup": "^4.62.2",
    "rollup-plugin-esbuild": "^6.2.1",
    "size-limit": "^12.1.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "peerDependencies": {
    "@yarnpkg/libzip": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@yarnpkg/libzip": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lockgraph/lockgraph.git"
  },
  "keywords": [
    "lockfile",
    "yarn",
    "npm",
    "pnpm",
    "bun",
    "audit",
    "convert"
  ],
  "author": "Anton Golub <antongolub@antongolub.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/lockgraph/lockgraph/issues"
  },
  "homepage": "https://github.com/lockgraph/lockgraph#readme",
  "packageManager": "npm@10.9.2"
}
