{
  "name": "lockgraph",
  "version": "0.0.0-snapshot.93",
  "private": false,
  "description": "Universal lockfile model and converter for npm, yarn, pnpm, bun",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./modify": {
      "types": "./dist/modify/index.d.ts",
      "default": "./dist/modify/index.js"
    },
    "./complete": {
      "types": "./dist/complete/index.d.ts",
      "default": "./dist/complete/index.js"
    },
    "./optimize": {
      "types": "./dist/optimize/index.d.ts",
      "default": "./dist/optimize/index.js"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "default": "./dist/registry/index.js"
    },
    "./enrich": {
      "types": "./dist/enrich/index.d.ts",
      "default": "./dist/enrich/index.js"
    },
    "./formats/*": {
      "types": "./dist/formats/*.d.ts",
      "default": "./dist/formats/*.js"
    },
    "./formats/_*": null
  },
  "typesVersions": {
    "*": {
      "modify": [
        "./dist/modify/index.d.ts"
      ],
      "complete": [
        "./dist/complete/index.d.ts"
      ],
      "optimize": [
        "./dist/optimize/index.d.ts"
      ],
      "registry": [
        "./dist/registry/index.d.ts"
      ],
      "enrich": [
        "./dist/enrich/index.d.ts"
      ],
      "formats/*": [
        "./dist/formats/*.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "ERRORS.md",
    "SCHEMAS.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=14.18"
  },
  "scripts": {
    "build:dist": "node scripts/clean.mjs && rollup -c && tsc -p tsconfig.dts.json && node scripts/fix-dts.mjs",
    "build:fixtures": "node src/test/resources/fixtures/_gen.mjs",
    "test:types": "tsc --noEmit",
    "test:unit": "vitest run src/test/unit",
    "test:integration": "vitest run src/test/interop src/test/infra",
    "test:frozen:bookend": "vitest run src/test/infra/frozen-conversion-oracle.test.ts",
    "test:frozen:pnpm-6": "vitest run src/test/infra/frozen-conversion-oracle.test.ts -t pm-pnpm-6",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:smoke": "node scripts/smoke.mjs",
    "test:size": "size-limit",
    "measure": "npm run build:dist && node scripts/measure.mjs",
    "measure:verify": "npm run build:dist && node scripts/measure.mjs --deterministic-only --verify-determinism",
    "prepublishOnly": "npm run build:dist"
  },
  "dependencies": {
    "node-fetch-native": "^1.6.7",
    "pako": "^3.0.0",
    "semver": "^7.8.5"
  },
  "devDependencies": {
    "@antongolub/artel": "^0.4.0",
    "@size-limit/file": "^12.1.0",
    "@types/node": "^22.10.0",
    "@types/pako": "^2.0.4",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@yarnpkg/libzip": "^3.2.2",
    "bun": "1.3.14",
    "pm-npm-10": "npm:npm@10.9.8",
    "pm-npm-11": "npm:npm@11.18.0",
    "pm-npm-12": "npm:npm@12.0.1",
    "pm-npm-6": "npm:npm@6.14.18",
    "pm-npm-7": "npm:npm@7.24.2",
    "pm-npm-8": "npm:npm@8.19.4",
    "pm-npm-9": "npm:npm@9.9.4",
    "pm-pnpm-10": "npm:pnpm@10.34.5",
    "pm-pnpm-6": "npm:pnpm@6.35.1",
    "pm-pnpm-7": "npm:pnpm@7.33.7",
    "pm-pnpm-8": "npm:pnpm@8.15.9",
    "pm-pnpm-9": "npm:pnpm@9.15.9",
    "pm-yarn-1": "npm:yarn@1.22.22",
    "pm-yarn-2": "npm:yarn@2.4.3",
    "pm-yarn-berry-v5": "npm:@yarnpkg/cli-dist@3.1.1",
    "pm-yarn-berry-v6": "npm:@yarnpkg/cli-dist@3.8.7",
    "pm-yarn-berry-v7": "npm:@yarnpkg/cli-dist@4.0.0-rc.46",
    "pm-yarn-berry-v8": "npm:@yarnpkg/cli-dist@4.13.0",
    "pm-yarn-berry-v9": "npm:@yarnpkg/cli-dist@4.14.1",
    "rollup": "^4.62.2",
    "rollup-plugin-esbuild": "^6.2.1",
    "size-limit": "^12.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@yarnpkg/libzip": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@yarnpkg/libzip": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lockgraph/lockgraph.git"
  },
  "keywords": [
    "lockfile",
    "yarn",
    "npm",
    "pnpm",
    "bun",
    "audit",
    "convert"
  ],
  "author": "Anton Golub <antongolub@antongolub.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/lockgraph/lockgraph/issues"
  },
  "homepage": "https://github.com/lockgraph/lockgraph#readme",
  "packageManager": "npm@10.9.8"
}
